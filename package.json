{
    "name": "pgats-02-api",
    "version": "1.0.0",
    "description": "API para aprendizado de testes e automação com Express e Swagger",
    "main": "server.js",
    "scripts": {
        "test": "mocha test/**/*.test.js --timeout 10000 --reporter mochawesome",
        "test-external": "mocha test/external/**/*.test.js --timeout 10000 --reporter mochawesome",
        "test-controller": "mocha test/controller/**/*.test.js --timeout 10000 --reporter mochawesome",
        "start": "node server.js"
    },
    "dependencies": {
        "chai": "^4.5.0",
        "express": "^4.18.2",
        "mocha": "^11.7.1",
        "sinon": "^21.0.0",
        "supertest": "^7.1.4",
        "swagger-ui-express": "^4.6.3"
    },
    "mocha": {
        "recursive": true
    },
    "devDependencies": {
        "mochawesome": "^7.1.3"
    }
}
